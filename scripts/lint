#!/bin/bash

PROJECT_DIR="$( cd "$(dirname "${BASH_SOURCE[0]}")" || exit; cd ..; pwd)"
cd "$PROJECT_DIR" || exit
# shellcheck disable=SC1091
. .venv/bin/activate

# Mirrors the jobs in .github/workflows/lint.yml. Runs every check even if an
# earlier one fails, so a single run reports everything that's wrong.
failed=()

run_check() {
    local name="$1"
    shift
    echo "=== ${name} ==="
    if "$@"; then
        echo "=== ${name}: OK ==="
    else
        echo "=== ${name}: FAILED ==="
        failed+=("$name")
    fi
    echo
}

run_check ruff ruff check .
run_check "ruff format" ruff format --check .
run_check bandit bandit -c pyproject.toml -q -r books loaning skoufas_library_project manage.py
run_check pip-audit pip-audit
run_check djlint djlint . --lint
run_check shellcheck shellcheck scripts/restart scripts/restart-venv scripts/update-messages scripts/lint
run_check check-manifest check-manifest
run_check pylint pylint .
DJANGO_CURRENT_SECRET_KEY="${DJANGO_CURRENT_SECRET_KEY:-ci-only-dummy-key}" \
DJANGO_OLD_SECRET_KEY="${DJANGO_OLD_SECRET_KEY:-ci-only-dummy-old-key}" \
run_check "migrations-check" python manage.py makemigrations --check --dry-run

if [ "${#failed[@]}" -eq 0 ]; then
    echo "All lint checks passed."
    exit 0
fi

echo "Failed: ${failed[*]}"
exit 1
