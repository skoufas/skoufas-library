#: curation/views.py:353
#, python-format
msgid "Merge undone. Author recreated as \"%(name)s\"."
msgstr "Η συγχώνευση αναιρέθηκε. Ο συγγραφέας αναδημιουργήθηκε ως \"%(name)s\"."

#: curation/views.py:368
msgid "Cannot undo: the target book entry no longer exists."
msgstr "Δεν είναι δυνατή η αναίρεση: η εγγραφή βιβλίου στόχος δεν υπάρχει πλέον."

#: curation/views.py:404
#, python-format
msgid "Merge undone. Book recreated as \"%(name)s\"."
msgstr "Η συγχώνευση αναιρέθηκε. Το βιβλίο αναδημιουργήθηκε ως \"%(name)s\"."
